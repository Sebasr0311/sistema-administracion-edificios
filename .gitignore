# =============================================================
# .gitignore — Sistema de Administración de Edificios
# Java + JavaFX + IntelliJ IDEA + Oracle SQL Express 18c
# =============================================================

# ----------------------------------------------------------
# IntelliJ IDEA
# ----------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ----------------------------------------------------------
# Archivos compilados de Java
# ----------------------------------------------------------
*.class
*.jar
!librerias/*.jar

# ----------------------------------------------------------
# Carpetas de compilación y construcción
# ----------------------------------------------------------
build/
target/
dist/
bin/

# ----------------------------------------------------------
# Driver JDBC de Oracle (no se versiona por tamaño/licencia)
# ----------------------------------------------------------
librerias/ojdbc*.jar
librerias/ucp*.jar

# ----------------------------------------------------------
# Archivos de configuración con credenciales (¡NUNCA en git!)
# ----------------------------------------------------------
src/main/recursos/configuracion/base-datos.properties
src/main/recursos/configuracion/*.properties
*.properties

# ----------------------------------------------------------
# PDFs de documentos subidos al sistema
# ----------------------------------------------------------
uploads/
documentos/
*.pdf

# ----------------------------------------------------------
# Sistema operativo
# ----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------
# Variables de entorno
# ----------------------------------------------------------
.env
.env.*

# ----------------------------------------------------------
# NetBeans (por si alguien usa NetBeans)
# ----------------------------------------------------------
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# ----------------------------------------------------------
# Eclipse (por si alguien usa Eclipse)
# ----------------------------------------------------------
.project
.classpath
.settings/
